# ParkSight AI frontend — environment configuration
# Copy to .env (or .env.local) and edit. Never commit the real file.
# Vite only exposes variables prefixed with VITE_ to client code — no API
# keys belong here; they live only in the backend's environment.

# Base URL of the FastAPI backend's /api routes.
VITE_API_BASE_URL=http://localhost:8000/api
