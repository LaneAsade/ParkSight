# ParkSight AI backend — environment configuration
# Copy to .env and edit. Never commit the real .env file.

# Where pipeline output artifacts live (a single run dir, or a parent dir
# containing several timestamped run subdirectories).
PARKSIGHT_OUTPUT_DIR=../outputs

# Source of truth for districts, weights, thresholds, shifts, economic
# assumptions, DBSCAN settings, road-capacity assumptions.
PARKSIGHT_SETTINGS_PATH=../config/settings.yaml

# Original input CSV (metadata only — never re-read per request).
PARKSIGHT_INPUT_CSV=../data/raw/violations.csv

# Optional: pin a specific run instead of auto-selecting the newest one.
# PARKSIGHT_RUN_ID=2026-06-20T10-00-00

# Comma-separated list of allowed frontend origins (CORS).
FRONTEND_ORIGIN=http://localhost:5173

# In-memory artifact cache (re-parses a file only when its mtime changes).
PARKSIGHT_CACHE_ENABLED=true

# Default team count used by GET /api/patrol/current and /api/overview's
# patrol-coverage figure.
PARKSIGHT_DEFAULT_TEAMS=10

# Responses larger than this many bytes get gzip-compressed.
PARKSIGHT_GZIP_MIN_SIZE=1000

# ── Secrets — read by the pipeline's own modules (parksight/*), never by
# the API layer, and never exposed to the frontend. Leave unset to run
# fully offline; outputs will be tagged SPEC_ONLY instead of REAL_DATA.
# GOOGLE_MAPS_API_KEY=
# MAPPLS_ACCESS_TOKEN=
# MAPPLS_CLIENT_ID=
# MAPPLS_CLIENT_SECRET=
