# ParkSight AI — root environment configuration.
# Copy to .env and edit. Never commit the real .env file.
#
# This file documents every secret used anywhere in the project. The
# backend and frontend also have their own .env.example with the subset
# relevant to each (backend/.env.example, frontend/.env.example) — when
# running each service independently, use those instead.

# ── Pipeline secrets (read only by parksight/*, never by the API layer or
# the frontend). Leave unset to run fully offline — traffic and road-
# geometry stages will produce SPEC_ONLY rows instead of failing.
GOOGLE_MAPS_API_KEY=
MAPPLS_ACCESS_TOKEN=
MAPPLS_CLIENT_ID=
MAPPLS_CLIENT_SECRET=

# ── Backend configuration (see backend/.env.example for the full set)
PARKSIGHT_OUTPUT_DIR=outputs
PARKSIGHT_SETTINGS_PATH=config/settings.yaml
PARKSIGHT_INPUT_CSV=data/raw/violations.csv
FRONTEND_ORIGIN=http://localhost:5173

# ── Frontend configuration (see frontend/.env.example)
VITE_API_BASE_URL=http://localhost:8000/api
